# OKX API - 实盘 (在 www.okx.com 创建)
OKX_API_KEY="your_real_api_key"
OKX_SECRET_KEY="your_real_secret_key"
OKX_PASSPHRASE="your_real_passphrase"

# OKX API - 模拟盘 (在模拟交易页面创建)
OKX_SIMULATED_API_KEY="your_simulated_api_key"
OKX_SIMULATED_SECRET_KEY="your_simulated_secret_key"
OKX_SIMULATED_PASSPHRASE="your_simulated_passphrase"

# OKX交易模式切换
# false = 使用实盘API Key (真实资金)
# true = 使用模拟盘API Key (虚拟资金)
OKX_TESTNET=true

# AI Provider (openai, qwen 或 doubao)
AI_PROVIDER=qwen

# OpenAI (必填)
OPENAI_BASE_URL=https://api.openai-hk.com/v1
OPENAI_API_KEY=hk-t6edni1xxx
OPENAI_MODEL=gpt-4o

# 通义千问 (如果使用qwen，设置AI_PROVIDER=qwen)
QWEN_API_KEY=sk-f4a098xxx
QWEN_MODEL=qwen2.5-72b-instruct

# 豆包大模型 (如果使用doubao，设置AI_PROVIDER=doubao)
DOUBAO_API_KEY=e3dacb9b-7922-404a-888b-7914c357ce36
DOUBAO_MODEL=doubao-seed-1-8-251228
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Trading Config
# 策略选择（对应 strategies/ 目录下的 YAML 文件，不含 .yaml 后缀）
# 可选策略:
#   - 15m_trend_following: 15分钟短线趋势跟随策略（默认）
#   - 5m_scalping: 5分钟超短线剥头皮策略
#   - 1h_swing: 1小时波段交易策略
# 详细说明请查看 docs/策略配置系统使用指南.md
STRATEGY_NAME=15m_trend_following

# 自动筛选标的开关（推荐开启）
# true: 每2小时自动运行 symbol_screener.py 筛选全市场，动态更新标的池（覆盖 SYMBOL_POOL 配置）
# false: 使用下方 SYMBOL_POOL 静态配置
ENABLE_AUTO_SCREENING=true

# 标的池（逗号分隔）
# - 当 ENABLE_AUTO_SCREENING=true 时：作为降级方案（筛选失败或 Redis 无数据时使用）
# - 当 ENABLE_AUTO_SCREENING=false 时：作为主配置，AI 在池中动态选择
# 单标的模式：只填一个标的，如 SYMBOL_POOL=BTC-USDT
# 多标的轮动：填多个标的，如下方示例
SYMBOL_POOL=BTC-USDT,ETH-USDT,SOL-USDT

TRADING_MODE=cash
INITIAL_CAPITAL=100.0
MAX_DAILY_RISK_PCT=3.0
CYCLE_INTERVAL_SECONDS=300
CYCLE_INTERVAL_NO_POSITION=900

# Redis (可选,不用可以不填)
USE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379

# Alert (可选)
ALERT_ENABLED=false
WEBHOOK_URL=

# DingTalk Notification (可选)
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
DINGTALK_SECRET=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ai_trader.log
