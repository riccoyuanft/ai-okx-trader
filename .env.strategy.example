# ==========================================
# 5分钟超短线现货做多策略 - 参数配置示例
# ==========================================
# 复制此文件为 .env 并根据需要调整参数
# 策略特点：波段快进快出、严控回撤、盈亏比1.1、止损0.3-0.4倍ATR

# ========== 仓位控制 ==========
MIN_POSITION_SIZE_PCT=20.0        # 最小仓位比例（弱多头下限）
MAX_POSITION_SIZE_PCT=70.0        # 最大仓位比例（强多头上限）
DEFAULT_POSITION_SIZE_PCT=40.0    # 默认仓位比例

# ========== 均线周期 ==========
MA_PERIOD_FAST=5                  # 快速均线周期
MA_PERIOD_MID=10                  # 中速均线周期
MA_PERIOD_SLOW=20                 # 慢速均线周期

# ========== 盈亏比与止损（新策略优化）==========
MIN_RISK_REWARD_RATIO=1.1         # 最低盈亏比要求（从1.2降至1.1，提高开仓机会）
MIN_STOP_LOSS_ATR_MULTIPLIER=0.3  # 止损空间最小倍数（从0.5降至0.3）
MAX_STOP_LOSS_ATR_MULTIPLIER=0.4  # 止损空间最大倍数（新增，控制止损范围）

# ========== 移动止损参数（更灵活）==========
TRAILING_STOP_TRIGGER_PCT=0.3     # 移动止损触发门槛（从0.5%降至0.3%，更灵活）
TRAILING_STOP_ATR_MULTIPLIER=0.3  # 移动止损安全间距倍数（从0.5降至0.3）
TRAILING_STOP_MIN_DISTANCE_PCT=0.2 # 移动止损最小间距（从0.3%降至0.2%）

# ========== RSI阈值 ==========
RSI_OVERBOUGHT=70.0               # RSI超买阈值
RSI_OVERSOLD=30.0                 # RSI超卖阈值

# ========== 风险管理（新增冷却机制）==========
MAX_CONSECUTIVE_LOSSES=2          # 连续亏损次数限制（从3降至2，触发30分钟冷却）
LOSS_PROTECTION_POSITION_PCT=30.0 # 连续亏损后的仓位限制

# ========== 入场价格容差 ==========
ENTRY_PRICE_TOLERANCE_PCT=2.0     # 入场价格相对当前价格的最大偏离(%)

# ========== 追高策略参数 ==========
CHASE_HIGH_POSITION_RATIO=0.7     # 追高仓位系数（相对最大仓位的比例）
CHASE_HIGH_CONFIRM_K=2            # 回踩确认所需的5分钟K线数

# ==========================================
# 参数调整建议（根据市场环境）
# ==========================================
# 
# 【激进场景】（趋势明确、波动适中）
# MIN_RISK_REWARD_RATIO=1.0
# MIN_STOP_LOSS_ATR_MULTIPLIER=0.25
# TRAILING_STOP_TRIGGER_PCT=0.2
# MAX_POSITION_SIZE_PCT=80.0
#
# 【保守场景】（震荡市、不确定性高）
# MIN_RISK_REWARD_RATIO=1.5
# MIN_STOP_LOSS_ATR_MULTIPLIER=0.5
# TRAILING_STOP_TRIGGER_PCT=0.5
# MAX_POSITION_SIZE_PCT=50.0
#
# 【标准场景】（当前默认值，平衡收益与风险）
# 适用于大部分市场环境

# ==========================================
# 典型调整场景
# ==========================================
#
# 场景1：入场机会太少
# MIN_RISK_REWARD_RATIO=1.0
# MIN_STOP_LOSS_ATR_MULTIPLIER=0.25
#
# 场景2：频繁被止损扫出
# TRAILING_STOP_ATR_MULTIPLIER=0.4
# TRAILING_STOP_MIN_DISTANCE_PCT=0.3
# MIN_STOP_LOSS_ATR_MULTIPLIER=0.4
#
# 场景3：需要提高盈利质量
# MIN_RISK_REWARD_RATIO=1.5
# MIN_POSITION_SIZE_PCT=30
#
# 场景4：连续亏损需要保护
# MAX_CONSECUTIVE_LOSSES=1
# LOSS_PROTECTION_POSITION_PCT=20
# MAX_POSITION_SIZE_PCT=50

# ============================================================================
# 限价单执行参数
# ============================================================================
# 限价单超时时间（秒），超时未成交将撤单并进入冷却期
# 建议范围：60-90秒，默认90秒
# LIMIT_ORDER_TIMEOUT=90

# 限价单失败后冷却时间（分钟），冷却期间拒绝所有开仓信号
# 建议范围：3-5分钟，默认3分钟
# ORDER_FAILED_COOLING=3

# 说明：
# - 限价单超时未成交 = 行情不配合，放弃本次开仓，绝不追价
# - 冷却机制避免频繁无效挂单，控制操作频次
# - 守住入场位风控底线，杜绝任何形式的追价买入
